---
import DownloadMethods from "@/components/DownloadMethods.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { copy, links } from "@/data/site";

const locale = "en";
const c = copy[locale];
---

<BaseLayout locale={locale} slug="download" title={c.download.title} description={c.download.description}>
  <section class="page-head wrap">
    <h1>{c.download.title}</h1>
    <p>{c.download.intro}</p>
  </section>
  <section class="wrap content-section">
    <DownloadMethods methods={c.download.methods} />
  </section>
  <section class="band">
    <div class="wrap split-action">
      <div>
        <h2>{c.download.releases}</h2>
        <p>{c.download.releasesBody}</p>
      </div>
      <a class="button" href={links.tzapReleases}>{c.download.releaseButton}</a>
    </div>
  </section>
</BaseLayout>
