---
import CodeBlock from "@/components/CodeBlock.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { copy, links } from "@/data/site";

const locale = "zh-Hans";
const c = copy[locale];
---

<BaseLayout locale={locale} slug="docs" title={c.docs.title} description={c.docs.description}>
  <section class="page-head wrap">
    <h1>{c.docs.title}</h1>
    <p>{c.docs.intro}</p>
  </section>
  <section class="wrap command-list">
    {c.docs.sections.map((section) => (
      <article class="command-item">
        <h2>{section.title}</h2>
        <CodeBlock code={section.command} />
      </article>
    ))}
    <a class="button secondary" href={links.tzapCliReference}>{c.docs.more}</a>
  </section>
</BaseLayout>
