---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { copy, defaultLocale, links, localeLabels, localizedPath, type Locale, type RouteSlug } from "@/data/site";
import "@/styles/global.css";

interface Props {
  locale?: Locale;
  slug?: RouteSlug;
  title: string;
  description: string;
}

const { locale = defaultLocale, slug = "", title, description } = Astro.props;
const pageTitle = title === copy[locale].titleSuffix ? title : `${title} | ${copy[locale].titleSuffix}`;
const canonical = new URL(localizedPath(locale, slug), links.site).toString();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/tzap-icon.png" type="image/png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL("/og/tzap-og.png", links.site).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    {Object.keys(localeLabels).map((lang) => (
      <link
        rel="alternate"
        hreflang={lang}
        href={new URL(localizedPath(lang as Locale, slug), links.site).toString()}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(localizedPath(defaultLocale, slug), links.site).toString()} />
  </head>
  <body>
    <a class="skip-link" href="#content">{copy[locale].skip}</a>
    <Header locale={locale} slug={slug} />
    <main id="content">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
