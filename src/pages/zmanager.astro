---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { copy, links } from "@/data/site";

const locale = "en";
const c = copy[locale];
---

<BaseLayout locale={locale} slug="zmanager" title={c.zmanager.title} description={c.zmanager.description}>
  <section class="page-head wrap">
    <h1>{c.zmanager.title}</h1>
    <p>{c.zmanager.body}</p>
    <p class="notice">{c.zmanager.openBoundary}</p>
    <div class="button-row">
      <a class="button" href={links.zmanagerRepo}>{c.zmanager.repoButton}</a>
      <a class="button secondary" href={links.zmanagerReleases}>{c.zmanager.releaseButton}</a>
    </div>
  </section>
  <section class="band">
    <div class="wrap">
      <h2>What it does</h2>
      <ul class="feature-list columns">
        {c.zmanager.features.map((feature) => <li>{feature}</li>)}
      </ul>
    </div>
  </section>
</BaseLayout>
