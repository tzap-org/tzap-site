---
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import { copy, links, localizedPath, type Locale, type RouteSlug } from "@/data/site";

interface Props {
  locale: Locale;
  slug: RouteSlug;
}

const { locale, slug } = Astro.props;
const c = copy[locale];
---

<footer class="site-footer">
  <div class="wrap footer-grid">
    <div>
      <strong>tzap.org</strong>
      <p>{c.footer}</p>
      <p class="muted">{c.openSourceNote}</p>
    </div>
    <div>
      <strong>{c.source}</strong>
      <a href={links.tzapRepo}>tzap GitHub</a>
      <a href={links.zmanagerRepo}>ZManager CLI</a>
      <a href={links.siteRepo}>{c.editSite}</a>
      <a href={localizedPath(locale, "sponsor")}>{c.support}</a>
    </div>
    <div>
      <strong>{c.language}</strong>
      <LanguageSwitcher locale={locale} slug={slug} />
    </div>
  </div>
</footer>
