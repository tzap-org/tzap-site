---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { copy, links } from "@/data/site";

const locale = "zh-Hans";
const c = copy[locale];
---

<BaseLayout locale={locale} slug="spec" title={c.spec.title} description={c.spec.description}>
  <section class="page-head wrap">
    <h1>{c.spec.title}</h1>
    <p>{c.spec.body}</p>
    <div class="button-row">
      <a class="button" href={links.tzapSpec}>{c.spec.specButton}</a>
      <a class="button secondary" href={links.tzapRepo}>{c.spec.repoButton}</a>
    </div>
  </section>
  <section class="band">
    <div class="wrap">
      <h2>{c.spec.notesTitle}</h2>
      <ul class="feature-list columns">
        {c.spec.notes.map((note) => <li>{note}</li>)}
      </ul>
    </div>
  </section>
</BaseLayout>
